# =============================================================================
# RunMind — Root environment template
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Backend ---
APP_NAME=runmind-api
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Gemini (gratuito via Google AI Studio) ---
GOOGLE_API_KEY=...

# --- WhatsApp ---
# provider: "evolution" (não-oficial) ou "cloud" (Cloud API oficial)
WHATSAPP_PROVIDER=evolution
# liga/desliga o canal WhatsApp inteiro (envio + watchdog)
WHATSAPP_ENABLED=false

# Evolution (não-oficial, Baileys)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=...
EVOLUTION_INSTANCE=...

# Cloud API oficial da Meta (preencher pra WHATSAPP_PROVIDER=cloud)
# token permanente do System User (Graph API)
WHATSAPP_CLOUD_TOKEN=...
# Phone Number ID do número registrado (developers.facebook.com → WhatsApp → API Setup)
WHATSAPP_PHONE_NUMBER_ID=...
# WhatsApp Business Account ID (WABA)
WHATSAPP_BUSINESS_ACCOUNT_ID=...
# App Secret (developers.facebook.com → app → Configurações → Básico) — valida a assinatura do webhook
WHATSAPP_APP_SECRET=...
# token que VOCÊ inventa; a Meta confere na verificação do webhook (GET)
WHATSAPP_VERIFY_TOKEN=...

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://backend:8000
NEXT_PUBLIC_APP_NAME=RunMind
