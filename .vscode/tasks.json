{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": {
        "group": "runmind",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "ngrok",
      "type": "shell",
      "command": "ngrok http --url=unopened-employed-cedar.ngrok-free.dev 8000",
      "isBackground": true,
      "presentation": {
        "group": "runmind",
        "panel": "dedicated",
        "reveal": "always",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "RunMind: start",
      "dependsOn": ["backend", "ngrok"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true },
      "runOptions": { "runOn": "folderOpen" },
      "problemMatcher": []
    }
  ]
}
